{
    "resources_directory": "../resources",
    "note_font_file": "fonts/MaxelFreePersonalUseRegular-G3AAP.ttf",
    "background_image": {
        "file": "textures/masazer.jpg",
        "placement": "centered"
    },
    "shader_directory": "../shaders",
    "inputs": {
        "video": {
            "enabled": true,
            "device": "/dev/video1",
            "format": "qvga",
            "scale": 0.25,
            "on_top": false,
            "position": {
                "x": 0.0,
                "y": 0.0
            }
        },
        "playback": {
            "enabled": false,
            "file": "/home/atom/Videos/video.mp4",
            "scale": 0.28,
            "on_top": true,
            "position": {
                "x": 0.02,
                "y": 0.02
            }
        },
        "background_color": {
            "r": 0.0,
            "g": 0.0,
            "b": 0.0,
            "a": 1.0
        },
        "audio": {
            "enabled": true,
            "device": "PCM2902 Audio Codec"
        },
        "midi": {
            "enabled": true,
            "device": "through"
        }
    },
    "show_status_overlay": false,
    "video": {
        "enabled": true,
        "shaders": [
            "pink_key.glsl"
        ]
    },
    "playback": {
        "enabled": false,
        "shaders": [
            "pixelize_loop.glsl"
        ]
    },
    "screen": {
        "enabled": true,
        "shaders": [
            "wireframe_sphere.glsl",
            "video_feedback.glsl"
        ]
    },
    "midi_cc_mappings": [
        {
            "layer": "screen",
            "shader": "wireframe_sphere.glsl",
            "uniform": "u_wire_density",
            "channel": 0,
            "cc": 91,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "screen",
            "shader": "pixelize_viewport.glsl",
            "uniform": "u_pixelize_amount",
            "channel": 0,
            "cc": 92,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_r",
            "channel": 0,
            "cc": 93,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_g",
            "channel": 0,
            "cc": 94,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_b",
            "channel": 0,
            "cc": 95,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        }
    ]
}