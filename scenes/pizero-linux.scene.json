{
    "resources_directory": "../resources/",
    "note_font_file": "fonts/MaxelFreePersonalUseRegular-G3AAP.ttf",
    "background_image": {
        "file": "textures/masazer.jpg",
        "placement": "centered"
    },
    "shader_directory": "../shaders/",
    "render_path": "qt-shader",
    "geometry": {
        "width": 1024,
        "height": 600
    },
    "inputs": {
        "video": {
            "enabled": true,
            "device": "/dev/video1",
            "format": "qvga",
            "scale": 0.25,
            "on_top": false,
            "position": {
                "x": 0.5,
                "y": 0.5
            }
        },
        "playback": {
            "enabled": false,
            "file": "/home/atom/Videos/video.mp4",
            "scale": 0.28,
            "on_top": true,
            "position": {
                "x": 0.02,
                "y": 0.02
            },
            "start_ms": 0,
            "loop_start_ms": 0,
            "loop_end_ms": null,
            "loop_repeat": 0,
            "playback_rate": 1.0,
            "playback_rate_looping": 1.0
        },
        "background_color": {
            "r": 0.0,
            "g": 0.0,
            "b": 0.0,
            "a": 1.0
        },
        "audio": {
            "enabled": true,
            "device": "PCM2902 Audio Codec"
        },
        "midi": {
            "enabled": true,
            "device": "SQ-1"
        }
    },
    "show_status_overlay": true,
    "video": {
        "enabled": true,
        "shaders": [
            "pink_key.glsl",
            "video_sphere.glsl"
        ]
    },
    "playback": {
        "enabled": false,
        "shaders": [
            "pixelize_loop.glsl"
        ]
    },
    "screen": {
        "enabled": true,
        "shaders": [
            "kaleidoscope.glsl"
        ]
    },
    "layer_order": [
        "screen",
        "playback",
        "video"
    ],
    "midi_cc_mappings": [
        {
            "layer": "screen",
            "shader": "wireframe_sphere.glsl",
            "uniform": "u_wire_density",
            "channel": 0,
            "cc": 91,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "screen",
            "shader": "pixelize_viewport.glsl",
            "uniform": "u_pixelize_amount",
            "channel": 0,
            "cc": 92,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_h",
            "channel": 0,
            "cc": 93,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_hrange",
            "channel": 0,
            "cc": 94,
            "min": 0.0,
            "max": 0.5,
            "exponent": 1.0
        },
        {
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_spread",
            "channel": 0,
            "cc": 95,
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        }
    ],
    "osc_mappings": [
        {
            "address": "/cockscreen/key/hue",
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_h",
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "address": "/cockscreen/key/hrange",
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_hrange",
            "min": 0.0,
            "max": 0.5,
            "exponent": 1.0
        },
        {
            "address": "/cockscreen/key/spread",
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_spread",
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        },
        {
            "address": "/cockscreen/key/smin",
            "layer": "video",
            "shader": "pink_key.glsl",
            "uniform": "u_key_smin",
            "min": 0.0,
            "max": 1.0,
            "exponent": 1.0
        }
    ]
}